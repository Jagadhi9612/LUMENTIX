# Elite Fitness web app
# Copy to apps/web/.env.local or root .env.local for local Next.js builds.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=elite-fitness-2026.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=elite-fitness-2026
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=elite-fitness-2026.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Firebase Functions use Application Default Credentials in Google Cloud.
# No service account key should be committed to this repository.
