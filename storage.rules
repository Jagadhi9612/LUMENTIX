rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return signedIn() && request.auth.token.role != null
        ? request.auth.token.role
        : null;
    }

    function canUploadMemberFiles() {
      return role() in ['SUPER_ADMIN', 'GYM_MANAGER', 'RECEPTIONIST', 'ACCOUNTANT'];
    }

    function canManageSystem() {
      return role() in ['SUPER_ADMIN', 'GYM_MANAGER'];
    }

    match /member-documents/{memberId}/{fileName} {
      allow read: if signedIn();
      allow write: if canUploadMemberFiles()
        && request.resource.size < 10 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*') || request.resource.contentType == 'application/pdf');
    }

    match /member-photos/{memberId}/{fileName} {
      allow read: if signedIn();
      allow write: if canUploadMemberFiles() && request.resource.size < 5 * 1024 * 1024 && request.resource.contentType.matches('image/.*');
    }

    match /settings/{fileName} {
      allow read: if signedIn();
      allow write: if canManageSystem()
        && request.resource.size < 5 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*') || request.resource.contentType == 'application/pdf');
    }
  }
}
