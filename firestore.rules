rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return signedIn() && request.auth.token.role != null
        ? request.auth.token.role
        : signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function canWriteOperations() {
      return role() in ['SUPER_ADMIN', 'GYM_MANAGER', 'RECEPTIONIST', 'ACCOUNTANT'];
    }

    function canManageSystem() {
      return role() in ['SUPER_ADMIN', 'GYM_MANAGER'];
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || canManageSystem());
      allow create, update, delete: if canManageSystem();
    }

    match /settings/{settingId} {
      allow read: if signedIn();
      allow write: if canManageSystem();
    }

    match /members/{docId} {
      allow read: if signedIn();
      allow create, update: if canWriteOperations();
      allow delete: if canManageSystem();
    }

    match /packages/{docId} {
      allow read: if signedIn();
      allow write: if canManageSystem();
    }

    match /payments/{docId} {
      allow read: if signedIn();
      allow create, update: if role() in ['SUPER_ADMIN', 'GYM_MANAGER', 'RECEPTIONIST', 'ACCOUNTANT'];
      allow delete: if canManageSystem();
    }

    match /attendance/{docId} {
      allow read: if signedIn();
      allow create, update: if role() in ['SUPER_ADMIN', 'GYM_MANAGER', 'RECEPTIONIST', 'TRAINER'];
      allow delete: if canManageSystem();
    }

    match /trainers/{docId} {
      allow read: if signedIn();
      allow write: if canManageSystem();
    }

    match /expenses/{docId} {
      allow read: if signedIn();
      allow write: if role() in ['SUPER_ADMIN', 'GYM_MANAGER', 'ACCOUNTANT'];
    }

    match /reports/{docId} {
      allow read: if signedIn();
      allow write: if canManageSystem();
    }

    match /notifications/{docId} {
      allow read: if signedIn();
      allow create, update: if canWriteOperations();
      allow delete: if canManageSystem();
    }

    match /memberDevices/{docId} {
      allow read: if canManageSystem();
      allow create, update, delete: if false;
    }

    match /auditLogs/{docId} {
      allow read: if canManageSystem();
      allow create, update, delete: if false;
    }

    match /systemJobs/{docId} {
      allow read: if canManageSystem();
      allow write: if false;
    }
  }
}
